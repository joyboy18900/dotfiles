#!/usr/bin/env bash
set -e

DOTFILES_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

link_file() {
    local src="$1" dst="$2"
    if [ -L "$dst" ] && [ "$(readlink "$dst")" = "$src" ]; then return; fi
    if [ -f "$dst" ] || [ -d "$dst" ] || [ -L "$dst" ]; then
        mv "$dst" "${dst}.backup"
    fi
    mkdir -p "$(dirname "$dst")"
    ln -s "$src" "$dst"
    echo "linked: $dst → $src"
}

install_homebrew() {
    command -v brew &>/dev/null && return
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
}

install_deps() {
    local brewfile="$DOTFILES_ROOT/homebrew/Brewfile"
    [ -f "$brewfile" ] && brew bundle --file="$brewfile" || echo "Warning: some brew packages could not be installed, continuing…"
}

create_symlinks() {
    find "$DOTFILES_ROOT" -name "*.symlink" | while read -r src; do
        topic="$(basename "$(dirname "$src")")"
        filename="$(basename "$src" .symlink)"
        if [ "$topic" = "fish" ]; then
            dst="$HOME/.config/fish/$filename"
        else
            dst="$HOME/$filename"
        fi
        link_file "$src" "$dst"
    done
}

install_fisher_plugins() {
    command -v fish &>/dev/null || return
    fish -c "
        if not functions -q fisher
            curl -sL https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish | source
            fisher install jorgebucaran/fisher
        end
        fisher update
    " 2>/dev/null
}

install_homebrew
install_deps
create_symlinks
install_fisher_plugins
